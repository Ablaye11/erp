# ===========================================================================
# Fichier de configuration des variables d'environnement
# COPIEZ ce fichier et renommez-le ".env" puis renseignez vos valeurs réelles.
# Le fichier ".env" NE DOIT PAS être commité dans git.
# ===========================================================================

# ── Sécurité ────────────────────────────────────────────────────────────────
# Générez une clé unique avec : python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=django-insecure-remplacez-cette-cle-par-une-cle-generee-en-production

# "True" en développement local, "False" obligatoire en production
DEBUG=True

# Liste des domaines autorisés en production, séparés par des virgules.
# Exemple : ALLOWED_HOSTS=monecole.sn,www.monecole.sn
ALLOWED_HOSTS=localhost,127.0.0.1

# ── Base de données ──────────────────────────────────────────────────────────
# En développement, laisser "sqlite" pour utiliser SQLite (aucune config supplémentaire).
# En production, mettre "postgres" et renseigner les paramètres ci-dessous.
DB_ENGINE=sqlite

# Paramètres PostgreSQL (uniquement si DB_ENGINE=postgres)
DB_NAME=school_erp_db
DB_USER=erp_user
DB_PASSWORD=motdepasse_securise
DB_HOST=localhost
DB_PORT=5432

# ── Email SMTP ───────────────────────────────────────────────────────────────
# En développement, les emails s'affichent dans la console (EMAIL_BACKEND=console).
# En production, mettre "smtp" et renseigner les paramètres ci-dessous.
EMAIL_BACKEND=console

# Paramètres SMTP (uniquement si EMAIL_BACKEND=smtp)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=votre@gmail.com
EMAIL_HOST_PASSWORD=votre_mot_de_passe_application
